---
// KonamiGame.astro — breakout easter egg with online leaderboard (desktop only).
// Retro-arcade skin: Press Start 2P, neon bricks, high-scores table (ordinal ranks,
// your row in yellow). Launch via the floating button, or the Konami code.
// Mobile gets MorpionGame (tic-tac-toe) instead — this island is hidden ≤767px,
// so the leaderboard never appears on mobile.
---

<!-- Floating launch button — arcade "insert coin" cabinet CTA (desktop only) -->
<button
  id="kg-launch"
  aria-label="Play breakout"
  class="kg-launch group fixed bottom-6 right-6 z-[9997] flex items-center"
>
  <span class="kg-coin" aria-hidden="true"><span class="kg-coin-clip"><span class="kg-coin-token"></span></span></span>
  <span class="kg-launch-lines">
    <span class="kg-launch-1">INSERT COIN</span>
    <span class="kg-launch-2">PRESS TO PLAY</span>
  </span>
</button>

<!-- Full-screen game overlay (pure-black arcade) -->
<div id="kg" class="fixed inset-0 z-[9998] hidden bg-black/70">
  <canvas id="kg-canvas" class="kg-canvas absolute inset-0 h-full w-full"></canvas>

  <!-- HUD: SCORE / LEVEL / LIVES -->
  <div class="pointer-events-none absolute inset-x-0 top-0 flex justify-between px-6 py-5 md:px-12">
    <div class="kg-hud">
      <span class="kg-hud-label">SCORE</span>
      <span id="kg-score" class="kg-hud-val kg-cyan">0</span>
      <span id="kg-combo" class="kg-combo"></span>
    </div>
    <div class="kg-hud kg-hud-c">
      <span class="kg-hud-label">LEVEL</span>
      <span id="kg-level" class="kg-hud-val">1/3</span>
    </div>
    <div class="kg-hud kg-hud-c">
      <span class="kg-hud-label" id="kg-time-label">TIME</span>
      <span id="kg-time" class="kg-hud-val kg-time">2:00</span>
    </div>
    <div class="kg-hud kg-hud-r">
      <span class="kg-hud-label">LIVES</span>
      <span id="kg-lives" class="kg-hud-val kg-red">●●●</span>
    </div>
  </div>

  <!-- MENU overlay (home + game over): high-scores table, pseudo input, start button -->
  <div id="kg-menu" class="kg-menu absolute inset-0 flex flex-col items-center justify-center gap-5 overflow-y-auto px-6 py-10 text-center">
    <h1 class="kg-title">HIGH&nbsp;SCORES</h1>
    <p id="kg-result" class="kg-result hidden"></p>

    <div class="kg-board">
      <div class="kg-board-head">
        <span>RANK</span><span class="kg-name">NAME</span><span class="kg-pts">SCORE</span>
      </div>
      <ol id="kg-board-list" class="kg-board-list"></ol>
    </div>

    <form id="kg-form" class="flex w-full max-w-[26rem] flex-col items-stretch gap-3">
      <input
        id="kg-pseudo"
        type="text"
        maxlength="16"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="YOUR NAME"
        class="kg-input"
      />
      <button id="kg-start" type="submit" class="kg-btn">NOUVELLE PARTIE</button>
      <p id="kg-hint" class="kg-hint"></p>
    </form>

    <p class="kg-controls">ARROWS MOVE - SPACE LAUNCH - ESC QUIT</p>
  </div>

  <!-- BANNER overlay (transient: launch prompt / ball lost / level cleared) -->
  <div id="kg-banner" class="pointer-events-none absolute inset-0 hidden flex-col items-center justify-center gap-4 px-8 text-center">
    <h2 id="kg-banner-title" class="kg-banner-title"></h2>
    <p id="kg-banner-msg" class="kg-banner-msg"></p>
    <p id="kg-banner-pulse" class="kg-pulse kg-banner-pulse"></p>
  </div>

  <button
    id="kg-close"
    aria-label="Close"
    class="absolute right-5 top-5 z-10 flex h-10 w-10 items-center justify-center rounded-md border border-[#333] bg-black/70 text-text-muted transition-colors hover:border-[#ffe74c] hover:text-[#ffe74c]"
  >
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>
</div>

<style is:global>
  /* Menu rows/cells are created in JS (createElement), so Astro's scoped styles
     would not reach them — keep this block global. All selectors are kg-prefixed. */

  /* Arcade font across the whole overlay (canvas draws its own text) */
  #kg { font-family: 'Press Start 2P', ui-monospace, SFMono-Regular, monospace; }

  @keyframes kg-pulse { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
  .kg-pulse { animation: kg-pulse 1.1s steps(2, jump-none) infinite; }

  /* near-black playfield (a sliver of the site still bleeds through) */
  .kg-canvas { background: rgba(0, 0, 0, 0.9); }
  /* breakout is the desktop game; mobile gets MorpionGame instead (whole island hidden) */
  @media (max-width: 767px) { #kg-launch { display: none !important; } }

  /* ── Launch button: "insert coin" arcade cabinet CTA ── */
  /* `display` stays a Tailwind utility (flex) so the .hidden toggle keeps working. */
  .kg-launch {
    gap: 0.7rem;
    font-family: 'Press Start 2P', ui-monospace, SFMono-Regular, monospace;
    color: #ffe74c;
    background: #0a0a0a;
    border: 2px solid #ffe74c;
    border-radius: 8px;
    padding: 0.7rem 0.95rem;
    cursor: pointer;
    animation: kg-launch-glow 1.8s ease-in-out infinite;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  @keyframes kg-launch-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(255, 231, 76, 0.25), 0 6px 18px rgba(0, 0, 0, 0.5); }
    50%      { box-shadow: 0 0 18px rgba(255, 231, 76, 0.55), 0 6px 18px rgba(0, 0, 0, 0.5); }
  }
  .kg-launch:hover {
    transform: translateY(-2px) scale(1.03);
    border-color: #fff3a0;
    box-shadow: 0 0 26px rgba(255, 231, 76, 0.7), 0 8px 22px rgba(0, 0, 0, 0.55);
  }
  .kg-launch-lines { display: flex; flex-direction: column; gap: 0.34rem; text-align: left; line-height: 1; }
  .kg-launch-1 { font-size: 0.55rem; letter-spacing: 1px; color: #ffe74c; }
  .kg-launch-2 { font-size: 0.46rem; letter-spacing: 1px; color: #3ad1ff; animation: kg-blink 1.1s steps(1, jump-none) infinite; }
  @keyframes kg-blink { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0.15; } }
  /* Coin slot — tall vertical opening (dark interior). Layers, back to front:
     z0 interior · z1 coin · z2 front lip (opaque, swallows the coin) · z3 yellow frame. */
  /* Tall vertical slot — opaque dark face + yellow frame. The round coin sits BEHIND it,
     so its right side is cut by the slot's left edge → it reads as half-inserted. */
  .kg-coin {
    position: relative; flex: none; width: 0.9rem; height: 2.6rem; margin-left: 0.45rem;
  }
  .kg-coin::before {           /* slot face (opaque), behind the coin */
    content: ''; position: absolute; inset: 0; z-index: 1;
    background: #0a0a0a; border: 3px solid #ffe74c; border-radius: 1px;
    box-shadow: inset 0 0 4px rgba(0, 0, 0, 0.85);
  }
  /* Clip region: extends left (so the coin's left overhang shows) but is bounded on the
     right by the slot's inner wall → the coin is cut at the slot's right edge. */
  .kg-coin-clip {
    position: absolute; left: -1.6rem; right: 3px; top: 0; bottom: 0;
    z-index: 3; overflow: hidden; pointer-events: none;
  }
  /* Round gold coin in front of the slot, overlapping its left mouth, cut at the right wall */
  .kg-coin-token {
    position: absolute; left: 0.55rem; top: 50%; pointer-events: none;
    width: 2rem; height: 2rem; border-radius: 50%;
    background: radial-gradient(circle at 36% 30%, #fff6c0, #ffd23a 50%, #c8920f 100%);
    border: 2px solid #6b5210;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.35), 0 1px 3px rgba(0, 0, 0, 0.5);
    transform: translate(0, -50%) rotate(-10deg);
    animation: kg-coin-bob 1.9s ease-in-out infinite;
  }
  .kg-coin-token::before {     /* inner ring — the coin's "0" */
    content: ''; position: absolute; left: 50%; top: 50%;
    width: 38%; height: 54%; border-radius: 50%;
    border: 2px solid rgba(107, 82, 16, 0.65);
    transform: translate(-50%, -50%);
  }
  /* Idle: gentle LEFT-RIGHT float at the slot mouth */
  @keyframes kg-coin-bob {
    0%, 100% { transform: translate(0, -50%) rotate(-10deg); }
    50%      { transform: translate(-0.16rem, -50%) rotate(-10deg); }
  }
  /* Insert: simple slide to the right — the coin enters the slot and the right wall (clip)
     swallows it. No flip, no scale. */
  .kg-coin-token.is-inserting { animation: kg-coin-insert 0.45s ease-in forwards !important; }
  @keyframes kg-coin-insert {
    0%   { transform: translate(0,    -50%) rotate(-10deg); }
    100% { transform: translate(2rem, -50%) rotate(-10deg); }
  }
  .kg-coin.is-inserting::before { animation: kg-slot-flash 0.5s ease; }
  @keyframes kg-slot-flash {
    0%, 100% { box-shadow: none; border-color: #ffe74c; }
    50%      { box-shadow: 0 0 12px 3px rgba(255, 231, 76, 0.85); border-color: #fff3a0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .kg-launch, .kg-launch-2, .kg-coin-token { animation: none; }
  }

  .kg-cyan { color: #3ad1ff; }
  .kg-red  { color: #ff3b3b; }

  /* ── HUD ── */
  .kg-hud { display: flex; flex-direction: column; gap: 0.4rem; line-height: 1; }
  .kg-hud-c { text-align: center; }
  .kg-hud-r { text-align: right; }
  .kg-hud-label { font-size: 0.5rem; letter-spacing: 1px; color: #6a6a6a; }
  .kg-hud-val { font-size: 0.9rem; color: #fff; }
  /* Combo chip — appears under SCORE when a multiplier is live, fades out on reset */
  .kg-combo {
    font-size: 0.62rem; letter-spacing: 1px; color: #ffe74c; min-height: 0.8rem;
    opacity: 0; transition: opacity 0.12s ease, transform 0.12s ease; transform: translateY(-2px);
  }
  .kg-combo.is-on { opacity: 1; transform: none; text-shadow: 0 0 10px rgba(255, 231, 76, 0.7); }
  /* Time-bonus countdown — drains from par to 0:00, turns red in the last 10s */
  .kg-time { font-variant-numeric: tabular-nums; transition: color 0.2s ease; }
  .kg-time.is-low { color: #ff3b3b; text-shadow: 0 0 10px rgba(255, 59, 59, 0.7); }
  /* ● / ○ aren't in Press Start 2P — render the lives dots in a monospace fallback */
  #kg-lives { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: 2px; }

  /* ── Menu ── */
  .kg-menu { background: #000; transition: opacity 0.2s ease; }
  .kg-title {
    font-size: clamp(1rem, 4vw, 1.9rem);
    line-height: 1.5; letter-spacing: 1px; color: #fff;
    text-shadow: 0 0 14px rgba(58, 209, 255, 0.55), 0 0 4px rgba(255, 255, 255, 0.4);
  }
  .kg-result { font-size: 0.7rem; line-height: 1.6; color: #ffe74c; }

  /* ── High-scores table ── */
  .kg-board { width: 100%; max-width: 26rem; }
  .kg-board-head,
  .kg-board-list li {
    display: grid;
    grid-template-columns: 4.25rem 1fr auto;
    gap: 1rem;
    align-items: center;
    text-align: left;
  }
  .kg-board-head {
    font-size: 0.55rem; color: #6a6a6a; letter-spacing: 1px;
    padding: 0 0.5rem 0.55rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
  }
  .kg-board-list { list-style: none; margin: 0.4rem 0 0; padding: 0; width: 100%; }
  .kg-board-list li {
    font-size: 0.7rem; line-height: 1.4; color: #fff;
    text-transform: uppercase;
    padding: 0.42rem 0.5rem; border-radius: 4px;
  }
  .kg-board-head .kg-name,
  .kg-board-list .kg-name { text-align: left; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .kg-board-head .kg-pts,
  .kg-board-list .kg-pts { text-align: right; font-variant-numeric: tabular-nums; }
  .kg-board-list .kg-rank { color: #6a6a6a; }
  .kg-board-list li.kg-me { color: #ffe74c; }                 /* your row, like the ref */
  .kg-board-list li.kg-me .kg-rank { color: #ffe74c; }
  .kg-board-list li.kg-me .kg-pts { text-shadow: 0 0 8px rgba(255, 231, 76, 0.6); }
  .kg-board-list .kg-empty { grid-column: 1 / -1; text-align: center; color: #555; font-size: 0.6rem; }
  .kg-board-list li.kg-ellip {
    display: block; text-align: center; color: #555;
    letter-spacing: 4px; padding: 0.25rem 0; font-size: 0.7rem;
  }

  /* ── Input + button ── */
  .kg-input {
    font: inherit; font-size: 0.72rem; text-transform: uppercase; text-align: center;
    color: #fff; background: #000; border: 2px solid #333; border-radius: 6px;
    padding: 0.8rem 1rem; outline: none; transition: border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .kg-input::placeholder { color: #4a4a4a; }
  .kg-input:focus { border-color: #3ad1ff; box-shadow: 0 0 12px rgba(58, 209, 255, 0.4); }
  .kg-btn {
    font: inherit; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px;
    color: #ffe74c; background: #000; border: 2px solid #ffe74c; border-radius: 6px;
    padding: 0.85rem 1rem; cursor: pointer; transition: background 0.12s ease, color 0.12s ease, box-shadow 0.12s ease;
  }
  .kg-btn:hover { background: #ffe74c; color: #000; box-shadow: 0 0 16px rgba(255, 231, 76, 0.5); }
  .kg-hint { min-height: 1rem; font-size: 0.52rem; line-height: 1.6; color: #ff6b6b; }
  .kg-controls { font-size: 0.5rem; letter-spacing: 1px; color: #555; }

  /* ── Banner ── */
  .kg-banner-title {
    font-size: clamp(1.1rem, 5vw, 2.2rem); color: #ffe74c; letter-spacing: 2px;
    text-shadow: 0 0 16px rgba(255, 231, 76, 0.6);
  }
  .kg-banner-msg { font-size: 0.7rem; line-height: 1.6; color: #cfcfcf; }
  .kg-banner-pulse { font-size: 0.62rem; letter-spacing: 1px; color: #3ad1ff; }
</style>

<script>
  const root = document.getElementById('kg');
  const cv = document.getElementById('kg-canvas') as HTMLCanvasElement | null;
  const launchBtn = document.getElementById('kg-launch');

  if (root && cv && launchBtn) {
    const ctx = cv.getContext('2d')!;
    const scoreEl = document.getElementById('kg-score')!;
    const comboEl = document.getElementById('kg-combo')!;
    const timeEl = document.getElementById('kg-time')!;
    const levelEl = document.getElementById('kg-level')!;
    const livesEl = document.getElementById('kg-lives')!;

    const menuEl = document.getElementById('kg-menu')!;
    const resultEl = document.getElementById('kg-result')!;
    const boardListEl = document.getElementById('kg-board-list')!;
    const formEl = document.getElementById('kg-form') as HTMLFormElement;
    const pseudoEl = document.getElementById('kg-pseudo') as HTMLInputElement;
    const startBtn = document.getElementById('kg-start')!;
    const hintEl = document.getElementById('kg-hint')!;

    const bannerEl = document.getElementById('kg-banner')!;
    const bannerTitleEl = document.getElementById('kg-banner-title')!;
    const bannerMsgEl = document.getElementById('kg-banner-msg')!;
    const bannerPulseEl = document.getElementById('kg-banner-pulse')!;

    // ── i18n (the island is locale-agnostic; pick strings from <html lang>) ──
    const FR = (document.documentElement.lang || 'en').toLowerCase().startsWith('fr');
    const T = FR ? {
      start: 'NOUVELLE PARTIE', replay: 'REJOUER',
      loading: 'CHARGEMENT...', empty: 'SOIS LE PREMIER !', unavailable: 'CLASSEMENT INDISPONIBLE',
      pseudoHint: '2-16 CAR. : LETTRES, CHIFFRES, _ -', rejected: 'PSEUDO REFUSE.',
      rateLimited: 'TROP DE TENTATIVES, REVIENS PLUS TARD.', submitting: 'ENVOI DU SCORE...',
      launch: 'ESPACE POUR LANCER', ballLost: 'BALLE PERDUE', press: 'ESPACE POUR CONTINUER',
      level: 'NIVEAU', cleared: 'NIVEAU FRANCHI !', win: 'VICTOIRE', over: 'PARTIE TERMINÉE',
      score: 'SCORE', rank: 'RANG', perfect: 'SANS FAUTE !', flawless: 'PARTIE PARFAITE !',
      timeLabel: 'TEMPS',
    } : {
      start: 'NEW GAME', replay: 'PLAY AGAIN',
      loading: 'LOADING...', empty: 'BE THE FIRST!', unavailable: 'LEADERBOARD UNAVAILABLE',
      pseudoHint: '2-16 CHARS: LETTERS, NUMBERS, _ -', rejected: 'NAME REJECTED.',
      rateLimited: 'TOO MANY TRIES, COME BACK LATER.', submitting: 'SUBMITTING SCORE...',
      launch: 'SPACE TO LAUNCH', ballLost: 'BALL LOST', press: 'SPACE TO CONTINUE',
      level: 'LEVEL', cleared: 'LEVEL CLEARED!', win: 'YOU WIN', over: 'GAME OVER',
      score: 'SCORE', rank: 'RANK', perfect: 'NO DEATHS!', flawless: 'FLAWLESS RUN!',
      timeLabel: 'TIME',
    };
    startBtn.textContent = T.start;
    document.getElementById('kg-time-label')!.textContent = T.timeLabel;
    const nf = new Intl.NumberFormat(FR ? 'fr-FR' : 'en-US');
    const PSEUDO_RE = /^[A-Za-z0-9_-]{2,16}$/;
    const perfNow = () => performance.now();
    // Arcade ordinal: 1ST, 2ND, 3RD, 4TH, 11TH, 21ST…
    function ordinal(n: number) {
      const s = ['TH', 'ST', 'ND', 'RD'], v = n % 100;
      return n + (s[(v - 20) % 10] || s[v] || s[0]);
    }

    // ── Level config — what changes across the 3 levels ──
    const LEVELS = [
      { speed: 5.0, maxSpeed: 11.0, paddleFactor: 0.140, solidMod: 5, par: 120 },
      { speed: 6.2, maxSpeed: 12.5, paddleFactor: 0.110, solidMod: 3, par: 110 },
      { speed: 7.5, maxSpeed: 14.0, paddleFactor: 0.085, solidMod: 2, par: 100 },
    ];
    // ── Scoring (bricks dominant; bonuses secondary) ──
    const LIVES_BONUS = 200;          // × lives remaining, at game end
    const LEVEL_BONUS = 200;          // × level number, per cleared level
    const TIME_BONUS = 10;            // × seconds under par, per cleared level
    // Combo: each brick destroyed before the ball touches the paddle again raises the
    // multiplier (×1, ×2 … capped). Resets on every paddle bounce / launch / ball lost.
    const COMBO_MAX = 5;              // multiplier ceiling for one ball flight
    const PERFECT_LEVEL_BONUS = 500;  // per level cleared without losing a life
    const FLAWLESS_BONUS = 1500;      // whole game won without ever dying

    let W = 0, H = 0, scale = 1, dpr = 1;
    let open = false;
    let pseudo = '';

    // --- State ---
    const PADDLE_H = 14;
    let BALL_R = 8;
    // px/py = previous-step position, kept so draw() can interpolate (smooth render).
    const paddle = { x: 0, y: 0, px: 0, w: 120, speed: 9 };
    const ball = { x: 0, y: 0, px: 0, py: 0, dx: 0, dy: 0, speed: 5, stuck: true };
    let score = 0, lives = 3, level = 1;
    let combo = 0;                  // bricks broken since the last paddle touch
    let lifeLostThisLevel = false;  // drives the per-level "no deaths" bonus
    let deaths = 0;                 // total deaths in the run → "flawless" bonus
    let lvl = LEVELS[0];
    let gameStart = 0;
    // Level timer counts ONLY active flight time: it runs between launch and ball
    // loss / level clear, and is frozen on the menu, the "space to launch" wait and
    // every banner. levelActiveMs banks completed segments; segStart times the live one.
    let levelActiveMs = 0, segStart = 0, timerActive = false;
    let lastTimeShown = NaN; // last integer second painted (skip redundant DOM writes)
    // start | playing | dead | levelclear | over
    let state = 'start';
    let bricks: any[] = [];
    let particles: any[] = [];
    const keys: Record<string, boolean> = {};

    // --- Bricks (neon arcade palette) ---
    const ROWS = 6;
    let COLS = 9;
    const PAD = 6;
    let TOP = 70, SIDE = 22, BW = 56, BH = 22;
    const rowColors = ['#ff3b3b', '#ff9f1c', '#ffe74c', '#2bff88', '#3ad1ff', '#b388ff'];
    const rowPoints = [60, 50, 40, 30, 20, 10];

    function buildBricks() {
      bricks = [];
      for (let r = 0; r < ROWS; r++) {
        for (let c = 0; c < COLS; c++) {
          const solid = (r < 2) && ((c + r) % lvl.solidMod === 0);
          bricks.push({
            r, c, x: 0, y: 0, w: BW, h: BH,
            color: rowColors[r], points: rowPoints[r],
            hp: solid ? 2 : 1, max: solid ? 2 : 1, alive: true,
          });
        }
      }
      layoutBricks();
    }

    function layoutBricks() {
      for (const b of bricks) {
        b.x = SIDE + b.c * (BW + PAD);
        b.y = TOP + b.r * (BH + PAD);
        b.w = BW; b.h = BH;
      }
    }

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      cv!.width = Math.round(W * dpr);
      cv!.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      scale = Math.max(0.85, Math.min(2.2, H / 680));

      SIDE = Math.max(24, W * 0.04);
      TOP = Math.max(70, H * 0.12);
      COLS = Math.min(18, Math.max(8, Math.round((W - SIDE * 2) / 120)));
      BW = (W - SIDE * 2 - PAD * (COLS - 1)) / COLS;
      BH = Math.max(20, Math.min(34, H * 0.035));

      BALL_R = 8 * scale;
      paddle.w = Math.min(280, Math.max(70, W * lvl.paddleFactor));
      paddle.y = H - 60 * scale;
      paddle.speed = 9 * scale;
      paddle.x = Math.max(8, Math.min(W - paddle.w - 8, paddle.x || (W / 2 - paddle.w / 2)));
      paddle.px = paddle.x;

      if (state === 'playing' || state === 'dead') layoutBricks();
      else buildBricks();
      if (ball.stuck) resetBall();
    }

    function resetBall() {
      ball.stuck = true;
      ball.speed = lvl.speed * scale;
      ball.x = paddle.x + paddle.w / 2;
      ball.y = paddle.y - BALL_R;
      ball.dx = 0; ball.dy = 0;
      ball.px = ball.x; ball.py = ball.y; // don't interpolate across the respawn jump
    }

    function setLevel(n: number) {
      level = n;
      lvl = LEVELS[n - 1];
      lifeLostThisLevel = false; // fresh level → eligible for the no-deaths bonus
      levelActiveMs = 0; timerActive = false; lastTimeShown = NaN; // reset the level clock
      paddle.w = Math.min(280, Math.max(70, W * lvl.paddleFactor));
      buildBricks();
      resetBall();
    }

    function startGame() {
      pseudoEl.blur(); // gameplay keys shouldn't land in the input
      score = 0; lives = 3; combo = 0; deaths = 0;
      paddle.x = W / 2 - paddle.w / 2;
      paddle.px = paddle.x;
      setLevel(1); // resets the level clock (frozen until the ball launches)
      particles = [];
      state = 'playing';
      gameStart = perfNow();
      updateHUD();
      updateTimer();
      hideMenu();
      banner('', '', T.launch);
    }

    function launchBall() {
      ball.stuck = false;
      combo = 0;
      if (!timerActive) { timerActive = true; segStart = perfNow(); } // clock starts on launch
      hideBanner();
      const ang = (-Math.PI / 4) - Math.random() * Math.PI / 2;
      ball.dx = Math.cos(ang) * ball.speed;
      ball.dy = Math.sin(ang) * ball.speed;
    }

    function spawnParticles(x: number, y: number, color: string) {
      for (let i = 0; i < 12; i++) {
        const a = Math.random() * Math.PI * 2;
        const sp = 1 + Math.random() * 3.5;
        particles.push({ x, y, dx: Math.cos(a) * sp, dy: Math.sin(a) * sp, life: 1, color, size: 2 + Math.random() * 3 });
      }
    }

    function updateHUD() {
      scoreEl.textContent = nf.format(score);
      levelEl.textContent = level + '/3';
      livesEl.textContent = '●'.repeat(Math.max(0, lives)) + '○'.repeat(Math.max(0, 3 - lives));
      const mult = Math.min(combo, COMBO_MAX);
      if (mult >= 2) {
        comboEl.textContent = 'COMBO ×' + mult;
        comboEl.classList.add('is-on');
      } else {
        comboEl.classList.remove('is-on');
      }
    }

    // Live time-bonus countdown (par − elapsed). Only writes the DOM when the shown
    // second changes; frozen automatically while not 'playing' (loop stops calling it).
    // Format a non-negative second count as M:SS.
    function fmtClock(sec: number) {
      const s = Math.floor(sec);
      return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');
    }
    function updateTimer() {
      const remaining = lvl.par - levelElapsedSec();
      let txt: string, keySec: number;
      if (remaining >= 0) {
        keySec = Math.ceil(remaining);    // countdown: par … 0:01
        txt = fmtClock(keySec);
      } else {
        keySec = Math.floor(remaining);   // overtime: distinct negative keys
        txt = '+' + fmtClock(-remaining); // counts up past the par: +0:00, +0:01 …
      }
      if (keySec !== lastTimeShown) {
        lastTimeShown = keySec;
        timeEl.textContent = txt;
      }
      timeEl.classList.toggle('is-low', remaining <= 10); // red in the last 10s and all overtime
    }

    // ── Overlay helpers ──
    function showMenu() {
      hideBanner();
      menuEl.classList.remove('opacity-0', 'pointer-events-none');
    }
    function hideMenu() { menuEl.classList.add('opacity-0', 'pointer-events-none'); }
    function banner(title: string, msg: string, pulse: string) {
      bannerTitleEl.textContent = title;
      bannerMsgEl.textContent = msg;
      bannerPulseEl.textContent = pulse;
      bannerEl.classList.remove('hidden');
      bannerEl.classList.add('flex');
    }
    function hideBanner() {
      bannerEl.classList.add('hidden');
      bannerEl.classList.remove('flex');
    }

    // ── Scoring helpers ──
    // Active play time this level, in seconds (banked segments + the live one).
    function levelElapsedSec() {
      return (levelActiveMs + (timerActive ? perfNow() - segStart : 0)) / 1000;
    }
    function timeBonus() {
      return Math.round(Math.max(0, lvl.par - levelElapsedSec()) * TIME_BONUS);
    }

    function clearLevel() {
      const perfect = lifeLostThisLevel ? 0 : PERFECT_LEVEL_BONUS;
      const gained = LEVEL_BONUS * level + timeBonus() + perfect;
      score += gained;
      combo = 0;
      updateHUD();
      if (level >= LEVELS.length) { endGame(true); return; }
      const clearedLevel = level;
      state = 'levelclear';
      setLevel(level + 1); // resets + freezes the clock for the next level
      updateHUD();
      const msg = `${T.cleared}${perfect ? ' ' + T.perfect : ''} +${nf.format(gained)}`;
      banner(`${T.level} ${clearedLevel}`, msg, T.press);
    }

    function endGame(won: boolean) {
      score += LIVES_BONUS * lives; // lives bonus, applied once at the end
      const flawless = won && deaths === 0;
      if (flawless) score += FLAWLESS_BONUS;
      updateHUD();
      state = 'over';
      const timeMs = Math.round(perfNow() - gameStart);
      resultEl.textContent = `${won ? T.win : T.over} - ${T.score} ${nf.format(score)}`;
      if (flawless) resultEl.textContent += ` - ${T.flawless}`;
      resultEl.classList.remove('hidden');
      startBtn.textContent = T.replay;
      showMenu();
      submitScore(timeMs);
    }

    function update(dt: number) {
      if (state !== 'playing') return;

      if (keys['ArrowLeft']) paddle.x -= paddle.speed * dt * PADDLE_BOOST;
      if (keys['ArrowRight']) paddle.x += paddle.speed * dt * PADDLE_BOOST;
      paddle.x = Math.max(8, Math.min(W - paddle.w - 8, paddle.x));

      if (ball.stuck) {
        ball.x = paddle.x + paddle.w / 2;
        ball.y = paddle.y - BALL_R;
      } else {
        ball.x += ball.dx * dt * BALL_BOOST;
        ball.y += ball.dy * dt * BALL_BOOST;

        if (ball.x - BALL_R < 0) { ball.x = BALL_R; ball.dx *= -1; }
        if (ball.x + BALL_R > W) { ball.x = W - BALL_R; ball.dx *= -1; }
        if (ball.y - BALL_R < 0) { ball.y = BALL_R; ball.dy *= -1; }

        if (ball.dy > 0 &&
            ball.y + BALL_R >= paddle.y &&
            ball.y + BALL_R <= paddle.y + PADDLE_H + 12 &&
            ball.x >= paddle.x && ball.x <= paddle.x + paddle.w) {
          const hit = (ball.x - (paddle.x + paddle.w / 2)) / (paddle.w / 2);
          const ang = hit * (Math.PI / 3);
          ball.speed = Math.min(ball.speed + 0.10 * scale, lvl.maxSpeed * scale);
          ball.dx = Math.sin(ang) * ball.speed;
          ball.dy = -Math.abs(Math.cos(ang) * ball.speed);
          ball.y = paddle.y - BALL_R - 1;
          combo = 0; // paddle touch ends the current chain
          updateHUD();
        }

        for (const b of bricks) {
          if (!b.alive) continue;
          if (ball.x + BALL_R > b.x && ball.x - BALL_R < b.x + b.w &&
              ball.y + BALL_R > b.y && ball.y - BALL_R < b.y + b.h) {
            const overlapL = (ball.x + BALL_R) - b.x;
            const overlapR = (b.x + b.w) - (ball.x - BALL_R);
            const overlapT = (ball.y + BALL_R) - b.y;
            const overlapB = (b.y + b.h) - (ball.y - BALL_R);
            const minX = Math.min(overlapL, overlapR);
            const minY = Math.min(overlapT, overlapB);
            if (minX < minY) ball.dx *= -1; else ball.dy *= -1;

            b.hp--;
            if (b.hp <= 0) {
              b.alive = false;
              combo++;
              score += b.points * Math.min(combo, COMBO_MAX); // chain multiplier
              spawnParticles(b.x + b.w / 2, b.y + b.h / 2, b.color);
            } else {
              spawnParticles(ball.x, ball.y, b.color);
            }
            updateHUD();
            break;
          }
        }

        if (bricks.every((b) => !b.alive)) {
          clearLevel();
        }

        if (state === 'playing' && ball.y - BALL_R > H) {
          lives--;
          deaths++;
          lifeLostThisLevel = true;
          combo = 0;
          if (timerActive) { levelActiveMs += perfNow() - segStart; timerActive = false; } // bank + freeze
          updateHUD();
          if (lives <= 0) {
            endGame(false);
          } else {
            state = 'dead';
            resetBall();
            banner(T.ballLost, '', T.press);
          }
        }
      }

      for (const p of particles) { p.x += p.dx * dt; p.y += p.dy * dt; p.dy += 0.12 * dt; p.life -= 0.035 * dt; }
      particles = particles.filter((p) => p.life > 0);
    }

    function roundRect(x: number, y: number, w: number, h: number, r: number) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function draw(alpha: number) {
      ctx.clearRect(0, 0, W, H);

      // Interpolate the moving bodies between the previous and current sim step.
      const bx = ball.px + (ball.x - ball.px) * alpha;
      const by = ball.py + (ball.y - ball.py) * alpha;
      const pxi = paddle.px + (paddle.x - paddle.px) * alpha;

      for (const b of bricks) {
        if (!b.alive) continue;
        ctx.save();
        ctx.shadowColor = b.color;
        ctx.shadowBlur = 14;
        ctx.fillStyle = b.color;
        ctx.globalAlpha = b.hp < b.max ? 0.5 : 1;
        roundRect(b.x, b.y, b.w, b.h, 3);
        ctx.fill();
        if (b.max > 1) {
          ctx.globalAlpha = 1;
          ctx.shadowBlur = 0;
          ctx.strokeStyle = 'rgba(255,255,255,0.7)';
          ctx.lineWidth = 2;
          roundRect(b.x + 3, b.y + 3, b.w - 6, b.h - 6, 2);
          ctx.stroke();
        }
        ctx.restore();
      }

      for (const p of particles) {
        ctx.save();
        ctx.globalAlpha = Math.max(0, p.life);
        ctx.fillStyle = p.color;
        ctx.shadowColor = p.color;
        ctx.shadowBlur = 8;
        ctx.fillRect(p.x, p.y, p.size, p.size);
        ctx.restore();
      }

      // paddle — cyan neon
      ctx.save();
      ctx.shadowColor = '#3ad1ff';
      ctx.shadowBlur = 18;
      const grad = ctx.createLinearGradient(pxi, 0, pxi + paddle.w, 0);
      grad.addColorStop(0, '#1b7fa0');
      grad.addColorStop(0.5, '#7fe8ff');
      grad.addColorStop(1, '#1b7fa0');
      ctx.fillStyle = grad;
      roundRect(pxi, paddle.y, paddle.w, PADDLE_H, 5);
      ctx.fill();
      ctx.restore();

      // ball — white core, cyan glow
      ctx.save();
      ctx.shadowColor = '#3ad1ff';
      ctx.shadowBlur = 22;
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      ctx.arc(bx, by, BALL_R, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    }

    // Frame-rate independence: scale all motion by dt, normalized so dt = 1.0 at
    // 60 Hz. On a 144 Hz monitor dt ≈ 0.42 (smaller step, more frames); on 30 Hz
    // dt ≈ 2.0 (bigger step, fewer frames) → identical real-time speed everywhere.
    // Global pace knob — speeds the whole sim (ball, paddle, particles) equally.
    // 1.0 = the old 60 Hz feel; 1.15 = ~15% faster everywhere.
    const GAME_SPEED = 1.15;
    // Ball-only extra pace, on top of GAME_SPEED. Multiplies the ball's step so the
    // ball feels snappier without making the particles twitchier. 1.0 = off.
    const BALL_BOOST = 1.32;
    // Paddle-only extra pace, on top of GAME_SPEED. Kept higher than BALL_BOOST so the
    // bar out-runs the faster ball and stays controllable. 1.0 = off.
    const PADDLE_BOOST = 1.40;

    // ── Fixed-timestep loop with render interpolation ──
    // The sim advances in CONSTANT steps (SIM_HZ), so per-step motion is perfectly
    // even — no performance.now() jitter → smooth like the old refresh-tied loop.
    // We accumulate real elapsed time and run as many fixed steps as it buys; draw()
    // then interpolates between the last two states by the leftover fraction, so it
    // stays fluid on ANY refresh rate (incl. 144 Hz, not a multiple of the sim rate).
    // Real-time speed is identical on every PC (ISO). Finer steps ⇒ less tunneling too.
    const SIM_HZ = 120;
    const STEP_MS = 1000 / SIM_HZ;
    const FIXED_DT = (60 / SIM_HZ) * GAME_SPEED; // one sim step in old "60 Hz frame" units
    let lastTime = 0, acc = 0;
    function loop(now: number) {
      if (!open) return;
      if (!lastTime) lastTime = now;
      let frame = now - lastTime;
      lastTime = now;
      if (frame > 250) frame = 250; // tab-switch / GC gap: cap so we don't burst-step
      acc += frame;
      let steps = 0;
      while (acc >= STEP_MS && steps < 8) { // step cap = spiral-of-death guard
        savePrev();
        update(FIXED_DT);
        acc -= STEP_MS;
        steps++;
      }
      updateTimer(); // frozen unless a flight segment is live (timerActive)
      draw(acc / STEP_MS); // leftover fraction (0..1) → interpolation factor
      requestAnimationFrame(loop);
    }

    // Snapshot positions before a sim step so draw() can interpolate toward the new ones.
    function savePrev() {
      ball.px = ball.x; ball.py = ball.y;
      paddle.px = paddle.x;
    }

    // ── Leaderboard (network) ──
    // Default view: top 10. When you're below the visible block, collapse to
    // top 3 + "…" + your neighbourhood (ranks me-1..me+1), your row highlighted.
    const meKeyOf = (s: string) => (s || '').trim().toLowerCase();

    function paintRows(list: any[], mine: string) {
      boardListEl.innerHTML = '';
      if (!list.length) {
        const li = document.createElement('li');
        li.innerHTML = `<span class="kg-empty">${T.empty}</span>`;
        boardListEl.appendChild(li);
        return;
      }
      for (const item of list) {
        const li = document.createElement('li');
        if (item.ellipsis) {
          li.className = 'kg-ellip';
          li.textContent = '...';
          boardListEl.appendChild(li);
          continue;
        }
        if ((item.pseudo || '').toLowerCase() === mine) li.classList.add('kg-me');
        const rank = document.createElement('span');
        rank.className = 'kg-rank';
        rank.textContent = ordinal(item.rank);
        const name = document.createElement('span');
        name.className = 'kg-name';
        name.textContent = item.pseudo;                // textContent → no HTML injection
        const pts = document.createElement('span');
        pts.className = 'kg-pts';
        pts.textContent = nf.format(item.score);
        li.append(rank, name, pts);
        boardListEl.appendChild(li);
      }
    }

    function renderView(view: any, mine: string) {
      const top = view.top || [];
      const me = view.me;
      let list: any[];
      if (me && me.rank > 10 && view.around && view.around.length) {
        list = top.slice(0, 3);
        if (view.around[0].rank > 4) list = [...list, { ellipsis: true }];
        for (const r of view.around) if (r.rank > 3) list.push(r);
      } else {
        list = top.slice(0, 10);
      }
      paintRows(list, mine);
    }

    async function refreshBoard(pseudoStr: string) {
      const key = meKeyOf(pseudoStr);
      const q = PSEUDO_RE.test(key) ? `?pseudo=${encodeURIComponent(key)}` : '';
      try {
        const res = await fetch('/api/scores' + q, { headers: { accept: 'application/json' } });
        if (!res.ok) throw new Error('http ' + res.status);
        renderView(await res.json(), key);
      } catch {
        boardListEl.innerHTML = `<li><span class="kg-empty">${T.unavailable}</span></li>`;
      }
    }

    function loadBoard() {
      boardListEl.innerHTML = `<li><span class="kg-empty">${T.loading}</span></li>`;
      refreshBoard(pseudoEl.value || pseudo);
    }

    async function submitScore(timeMs: number) {
      hintEl.textContent = T.submitting;
      try {
        const res = await fetch('/api/scores', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ pseudo, score, level, time: timeMs }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          hintEl.textContent = '';
          if (data.me && data.me.rank) resultEl.textContent += ` - ${T.rank} ${ordinal(data.me.rank)}`;
          renderView(data, meKeyOf(pseudo));
        } else if (res.status === 429) {
          hintEl.textContent = T.rateLimited;
        } else if (data.error === 'pseudo_rejected') {
          hintEl.textContent = T.rejected;
        } else {
          hintEl.textContent = T.unavailable;
        }
      } catch {
        hintEl.textContent = T.unavailable; // offline: score kept locally only
      }
    }

    // ── Start a run from the menu (validates pseudo) ──
    function tryStart() {
      const v = pseudoEl.value.trim();
      if (!PSEUDO_RE.test(v)) {
        hintEl.textContent = T.pseudoHint;
        pseudoEl.focus();
        return;
      }
      pseudo = v;
      localStorage.setItem('kg-pseudo', v);
      hintEl.textContent = '';
      resultEl.classList.add('hidden');
      startGame();
    }

    // --- Open / close ---
    function openGame() {
      if (open) return;
      open = true;
      root!.classList.remove('hidden');
      launchBtn!.classList.add('hidden');
      document.body.style.overflow = 'hidden';
      state = 'start';
      level = 1; lvl = LEVELS[0];
      levelActiveMs = 0; timerActive = false; lastTimeShown = NaN; // show full par on the menu
      pseudo = localStorage.getItem('kg-pseudo') || '';
      pseudoEl.value = pseudo;
      resultEl.classList.add('hidden');
      startBtn.textContent = T.start;
      hintEl.textContent = '';
      resize();
      updateHUD();
      showMenu();
      loadBoard();
      // @ts-ignore — optional analytics
      if (window.plausible) window.plausible('breakout-game');
      lastTime = 0; acc = 0; // fresh clock + accumulator so the first frame is clean
      requestAnimationFrame(loop);
    }

    function closeGame() {
      open = false;
      root!.classList.add('hidden');
      launchBtn!.classList.remove('hidden');
      document.body.style.overflow = '';
    }

    // ── Advance from a transient pause (ball lost / level cleared) ──
    function continuePlay() {
      // Clock stays frozen here; it only restarts on the next launchBall().
      if (state === 'dead' || state === 'levelclear') {
        state = 'playing';
        hideBanner();
        banner('', '', T.launch);
      }
    }

    // --- Input (gameplay) ---
    function handleGameKey(e: KeyboardEvent) {
      if (e.key === 'Escape') { closeGame(); return; }
      // let the pseudo input receive normal typing while the menu is up
      if (state === 'start' || state === 'over') {
        if (e.key === ' ' && document.activeElement !== pseudoEl) { e.preventDefault(); tryStart(); }
        return;
      }
      if (['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', ' '].includes(e.key)) e.preventDefault();
      keys[e.key] = true;
      if (e.key === ' ') {
        if (state === 'dead' || state === 'levelclear') continuePlay();
        else if (state === 'playing' && ball.stuck) launchBall();
      }
    }

    window.addEventListener('keyup', (e) => { keys[e.key] = false; });

    // Pointer controls — click to launch / continue only (paddle is keyboard-driven)
    cv.addEventListener('pointerdown', (e) => {
      if (!open) return;
      if (state === 'dead' || state === 'levelclear') { e.preventDefault(); continuePlay(); }
      else if (state === 'playing' && ball.stuck) { e.preventDefault(); launchBall(); }
    });

    formEl.addEventListener('submit', (e) => { e.preventDefault(); tryStart(); });
    // Live-refresh the board around the typed pseudo (debounced) while the menu is up
    let boardDebounce = 0;
    pseudoEl.addEventListener('input', () => {
      window.clearTimeout(boardDebounce);
      boardDebounce = window.setTimeout(() => {
        if (state === 'start' || state === 'over') refreshBoard(pseudoEl.value);
      }, 400);
    });
    // Click the cabinet button → drop a coin into the slot, then open. Keyboard /
    // Konami paths call openGame() directly (instant, no animation).
    function insertCoinThenOpen() {
      if (open) return;
      const token = launchBtn!.querySelector('.kg-coin-token');
      const slot = launchBtn!.querySelector('.kg-coin');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !token) { openGame(); return; }
      token.classList.add('is-inserting');
      slot && slot.classList.add('is-inserting');
      window.setTimeout(() => {
        token.classList.remove('is-inserting');
        slot && slot.classList.remove('is-inserting');
        openGame();
      }, 470);
    }
    launchBtn.addEventListener('click', insertCoinThenOpen);
    document.getElementById('kg-close')!.addEventListener('click', closeGame);
    window.addEventListener('resize', () => { if (open) resize(); });

    // --- Konami code (bonus trigger) ---
    const SEQ = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
    let pos = 0;
    window.addEventListener('keydown', (e) => {
      if (open) { handleGameKey(e); return; }
      const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
      pos = (k === SEQ[pos]) ? pos + 1 : (k === SEQ[0] ? 1 : 0);
      if (pos === SEQ.length) { pos = 0; openGame(); }
    });
  }
</script>
